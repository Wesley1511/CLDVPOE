@model CLDVPOE.Models.Event

<h2>Edit Event</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div style="color:red">
        @Html.ValidationSummary(false)
    </div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="EventID" />

    <div>
        <label asp-for="EventName">Name</label>
        <input asp-for="EventName" />
        <span asp-validation-for="EventName" style="color:red"></span>
    </div>

    <div>
        <label asp-for="StartDate">Start Date</label>
        <input asp-for="StartDate" type="date" />
        <span asp-validation-for="StartDate" style="color:red"></span>
    </div>

    <div>
        <label asp-for="EndDate">End Date</label>
        <input asp-for="EndDate" type="date" />
        <span asp-validation-for="EndDate" style="color:red"></span>
    </div>
    <div>
        <label asp-for="EventDescription">Description</label>
        <input asp-for="EventDescription" />
        <span asp-validation-for="EventDescription" style="color:red"></span>
    </div>

    <button type="submit">Save Changes</button>
    <a href="/Event">Cancel</a>
</form>