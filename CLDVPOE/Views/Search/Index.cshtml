@model CLDVPOE.Models.SearchResultsViewModel

<h2>Search Results for "@Model.Query"</h2>

@if (Model.Venues.Count == 0 && Model.Events.Count == 0 && Model.Bookings.Count == 0)
{
    <p>No results found.</p>
}

@if (Model.Venues.Count > 0)
{
    <h3>Venues</h3>
    <table>
        <tr>
            <th>Name</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Image</th>
            <th>Actions</th>
        </tr>
        @foreach (var v in Model.Venues)
        {
            <tr>
                <td>@v.VenueName</td>
                <td>@v.Location</td>
                <td>@v.Capacity</td>
                <td>
                    @if (!string.IsNullOrEmpty(v.ImagePath))
                    {
                        <img src="@v.ImagePath" width="100" />
                    }
                </td>
                <td>
                    <a href="/Venue/Edit/@v.VenueID">Edit</a> |
                    <a href="/Venue/Delete/@v.VenueID">Delete</a>
                </td>
            </tr>
        }
    </table>
}

@if (Model.Events.Count > 0)
{
    <h3>Events</h3>
    <table>
        <tr>
            <th>Name</th>
            <th>Start</th>
            <th>End</th>
            <th>Actions</th>
        </tr>
        @foreach (var e in Model.Events)
        {
            <tr>
                <td>@e.EventName</td>
                <td>@e.StartDate.ToShortDateString()</td>
                <td>@e.EndDate.ToShortDateString()</td>
                <td>
                    <a href="/Event/Edit/@e.EventID">Edit</a> |
                    <a href="/Event/Delete/@e.EventID">Delete</a>
                </td>
            </tr>
        }
    </table>
}

@if (Model.Bookings.Count > 0)
{
    <h3>Bookings</h3>
    <table>
        <tr>
            <th>BookingID</th>
            <th>Status</th>
            <th>Event</th>
            <th>Description</th>
            <th>Venue</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>

        @foreach (var b in Model.Bookings)
        {
            <tr>
                <td>@b.BookingID</td>
                <td>@b.BookingStatus</td>
                <td>@b.Event?.EventName</td>
                <td>@b.Event?.EventDescription</td>
                <td>@b.Venue?.VenueName</td>
                <td>@b.BookingDate.ToShortDateString()</td>
                <td>
                    <a href="/Booking/Edit/@b.BookingID">Edit</a> |
                    <a href="/Booking/Delete/@b.BookingID">Delete</a>
                </td>
            </tr>
        }
    </table>
}