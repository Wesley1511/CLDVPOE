@{
    ViewData["Title"] = "Home";
}

<style>
    .content {
        padding: 0 !important;
        width: 100% !important;
        max-width: 100% !important;
        align-items: stretch !important;
    }

    .hero {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        width: 100%;
        text-align: center;
        background-image: url('/images/EventEaseBack.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .hero-text h1 {
        font-size: 52px;
        color: white;
        margin-bottom: 10px;
        text-shadow: 2px 2px 6px rgba(0,0,0,0.6);
    }

    .hero-text p {
        font-size: 22px;
        color: white;
        text-shadow: 2px 2px 6px rgba(0,0,0,0.6);
    }
</style>

<div class="hero">
    <div class="hero-text">
        <h1>Event Ease</h1>
        <p>The Event Management System for you</p>
    </div>
</div>