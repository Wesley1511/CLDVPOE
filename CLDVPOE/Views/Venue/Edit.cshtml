@model CLDVPOE.Models.Venue

<h2>Edit Venue</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div style="color:red">
        @Html.ValidationSummary(false)
    </div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="VenueID" />
    <input type="hidden" asp-for="ImagePath" />

    <div>
        <label asp-for="VenueName">Name</label>
        <input asp-for="VenueName" />
        <span asp-validation-for="VenueName" style="color:red"></span>
    </div>

    <div>
        <label asp-for="Location">Location</label>
        <input asp-for="Location" />
        <span asp-validation-for="Location" style="color:red"></span>
    </div>

    <div>
        <label asp-for="Capacity">Capacity</label>
        <input asp-for="Capacity" />
        <span asp-validation-for="Capacity" style="color:red"></span>
    </div>

    <div>
        <label>Current Image</label><br />
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" width="100" />
        }
    </div>

    <div>
        <label>Upload New Image (optional)</label>
        <input type="file" name="imageFile" />
    </div>

    <button type="submit">Save Changes</button>
    <a href="/Venue">Cancel</a>
</form>