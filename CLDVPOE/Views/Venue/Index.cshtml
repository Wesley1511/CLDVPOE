@model IEnumerable<CLDVPOE.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<h1>Venues</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Venue</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.VenueName</td>
                <td>@item.Location</td>
                <td>@item.Capacity</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.VenueID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.VenueID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.VenueID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>